# WebSocket (priority 1)
# NEXT_PUBLIC_EVENT_WS_URL=wss://example.com/events

# Server-Sent Events (priority 2)
# NEXT_PUBLIC_EVENT_STREAM_URL=https://example.com/events/stream

# HTTP Polling (priority 3)
# NEXT_PUBLIC_EVENT_API_URL=https://example.com/events
# NEXT_PUBLIC_EVENT_POLL_MS=5000

# Optional Korean public-data enrichment readiness.
# Keep real provider keys server-side.
# SEOUL_OPEN_DATA_API_KEY=
# DATA_GO_KR_SERVICE_KEY=
# TOPIS_API_KEY=
# EXPRESSWAY_API_KEY=
# KMA_API_KEY=
# AIRKOREA_API_KEY=
# PUBLIC_SAFETY_API_KEY=
# NATIONAL_FIRE_API_KEY=

# OpenRouter hosted LLM routing (optional; keep key server-side only)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3.5-flash
OPENROUTER_HTTP_REFERER=https://twincity-ui.pages.dev
OPENROUTER_APP_TITLE=twincity-ui
